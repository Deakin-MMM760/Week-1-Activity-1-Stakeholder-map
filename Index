<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>MMM760 | Week 1 | Activity 1 — Stakeholder map</title>

  <!-- DOCX export libraries (client-side) -->
  <script defer src="https://cdn.jsdelivr.net/npm/docx@8.5.0/build/index.umd.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

  <style>
    :root{
      /* Deakin-ish palette (teal-led, clean neutrals) */
      --dk-teal: #007A78;
      --dk-teal-dark:#005f5d;
      --dk-ink:#1f2a30;
      --dk-muted:#5b6b75;
      --dk-bg:#f6f8f9;
      --dk-card:#ffffff;
      --dk-border:#d6e1e5;
      --dk-soft:#eef6f6;
      --dk-warn:#b42318;
      --dk-ok:#067647;

      --radius:16px;
      --shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
      --shadow-soft: 0 6px 18px rgba(15, 23, 42, 0.06);
      --maxw: 1100px;
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
      color:var(--dk-ink);
      background:linear-gradient(180deg, var(--dk-soft) 0%, var(--dk-bg) 25%, var(--dk-bg) 100%);
      line-height:1.55;
    }

    a{color:var(--dk-teal); text-decoration:none}
    a:hover{text-decoration:underline}

    .topbar{
      background:linear-gradient(90deg, var(--dk-teal) 0%, var(--dk-teal-dark) 100%);
      color:#fff;
      padding:18px 16px;
      position:sticky;
      top:0;
      z-index:50;
      box-shadow: var(--shadow-soft);
    }

    .topbar-inner{
      max-width:var(--maxw);
      margin:0 auto;
      display:flex;
      gap:14px;
      align-items:flex-start;
      justify-content:space-between;
      flex-wrap:wrap;
    }

    .brand{
      display:flex;
      flex-direction:column;
      gap:2px;
      min-width:280px;
    }
    .brand .kicker{
      font-size:0.86rem;
      opacity:0.9;
      letter-spacing:0.2px;
    }
    .brand h1{
      margin:0;
      font-size:1.15rem;
      font-weight:750;
      letter-spacing:0.2px;
    }

    .top-actions{
      display:flex;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .pill{
      background:rgba(255,255,255,0.14);
      border:1px solid rgba(255,255,255,0.22);
      color:#fff;
      padding:8px 10px;
      border-radius:999px;
      font-size:0.9rem;
      display:flex;
      gap:8px;
      align-items:center;
      white-space:nowrap;
    }

    .wrap{
      max-width:var(--maxw);
      margin:0 auto;
      padding:22px 16px 110px;
    }

    .grid{
      display:grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap:14px;
    }

    @media (max-width: 980px){
      .grid{grid-template-columns:1fr;}
    }

    .card{
      background:var(--dk-card);
      border:1px solid var(--dk-border);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      padding:18px;
    }

    .card h2{
      margin:0 0 8px 0;
      font-size:1.18rem;
      letter-spacing:0.1px;
    }

    .card h3{
      margin:16px 0 8px 0;
      font-size:1.02rem;
    }

    .muted{color:var(--dk-muted)}
    .small{font-size:0.92rem}

    .notice{
      background:#fff;
      border:1px solid var(--dk-border);
      border-left:6px solid var(--dk-teal);
      border-radius:14px;
      padding:12px 12px;
    }

    .notice strong{color:var(--dk-teal-dark)}

    .fields{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:10px;
    }
    @media (max-width: 760px){
      .fields{grid-template-columns:1fr;}
    }

    label{
      display:block;
      font-weight:650;
      font-size:0.92rem;
      margin:0 0 6px 0;
    }

    input[type="text"], input[type="date"], textarea{
      width:100%;
      border:1px solid var(--dk-border);
      border-radius:12px;
      padding:10px 11px;
      font-size:0.98rem;
      outline:none;
      background:#fff;
    }
    textarea{min-height:96px; resize:vertical}

    input:focus, textarea:focus{
      border-color: rgba(0,122,120,0.55);
      box-shadow: 0 0 0 4px rgba(0,122,120,0.12);
    }

    .table-wrap{
      overflow:auto;
      border:1px solid var(--dk-border);
      border-radius:14px;
    }

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0;
      min-width:820px;
      background:#fff;
    }

    thead th{
      position:sticky;
      top:0;
      background:linear-gradient(90deg, rgba(0,122,120,0.10) 0%, rgba(0,95,93,0.08) 100%);
      color:var(--dk-ink);
      text-align:left;
      font-size:0.92rem;
      padding:10px;
      border-bottom:1px solid var(--dk-border);
    }

    tbody td{
      padding:10px;
      vertical-align:top;
      border-bottom:1px solid var(--dk-border);
    }
    tbody tr:last-child td{border-bottom:none}

    .cell-input input[type="text"], .cell-input textarea{
      border-radius:10px;
      padding:9px 10px;
      font-size:0.95rem;
    }
    .cell-input textarea{min-height:70px}

    .row-actions{
      display:flex;
      gap:8px;
      align-items:center;
      justify-content:flex-end;
      min-width:120px;
    }

    .btn{
      border:none;
      cursor:pointer;
      border-radius:999px;
      padding:10px 12px;
      font-weight:700;
      font-size:0.95rem;
      display:inline-flex;
      align-items:center;
      gap:8px;
      transition:transform 0.04s ease, box-shadow 0.2s ease, background 0.2s ease;
      user-select:none;
      text-decoration:none;
    }
    .btn:active{transform:translateY(1px)}
    .btn-primary{
      background:var(--dk-teal);
      color:#fff;
      box-shadow: 0 10px 18px rgba(0,122,120,0.22);
    }
    .btn-primary:hover{background:var(--dk-teal-dark)}
    .btn-ghost{
      background:#fff;
      color:var(--dk-teal-dark);
      border:1px solid rgba(0,122,120,0.25);
    }
    .btn-ghost:hover{background:rgba(0,122,120,0.06)}
    .btn-danger{
      background:#fff;
      color:var(--dk-warn);
      border:1px solid rgba(180,35,24,0.25);
    }
    .btn-danger:hover{background:rgba(180,35,24,0.05)}

    .right-stack{
      display:flex;
      flex-direction:column;
      gap:12px;
    }

    .status{
      display:flex;
      flex-direction:column;
      gap:8px;
    }
    .badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      border-radius:999px;
      padding:7px 10px;
      font-weight:750;
      font-size:0.9rem;
      width:fit-content;
      border:1px solid var(--dk-border);
      background:#fff;
    }
    .badge.ok{border-color: rgba(6,118,71,0.25); background: rgba(6,118,71,0.06); color: var(--dk-ok);}
    .badge.warn{border-color: rgba(180,35,24,0.22); background: rgba(180,35,24,0.06); color: var(--dk-warn);}

    .sticky-footer{
      position:fixed;
      left:0; right:0; bottom:0;
      background:rgba(246,248,249,0.92);
      backdrop-filter:saturate(180%) blur(10px);
      border-top:1px solid var(--dk-border);
      padding:12px 12px;
      z-index:60;
    }
    .sticky-inner{
      max-width:var(--maxw);
      margin:0 auto;
      display:flex;
      gap:10px;
      align-items:center;
      justify-content:space-between;
      flex-wrap:wrap;
    }
    .footer-left{display:flex; gap:10px; align-items:center; flex-wrap:wrap;}
    .footer-right{display:flex; gap:10px; align-items:center; flex-wrap:wrap;}

    .hint{
      font-size:0.9rem;
      color:var(--dk-muted);
    }

    .divider{
      height:1px;
      background:var(--dk-border);
      margin:14px 0;
    }

    .tiny{
      font-size:0.82rem;
      color:var(--dk-muted);
    }

    .kbd{
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size:0.85rem;
      padding:2px 6px;
      border:1px solid var(--dk-border);
      border-radius:8px;
      background:#fff;
    }
  </style>
</head>

<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <div class="kicker">MMM760 Small Business Management</div>
        <h1>Week 1 • Activity 1 — Stakeholder map (draft)</h1>
      </div>

      <div class="top-actions">
        <div class="pill" id="savePill" aria-live="polite">Not saved yet</div>
        <a class="pill" href="javascript:window.print()" title="Print / Save as PDF">Print / Save as PDF</a>
      </div>
    </div>
  </header>

  <main class="wrap">
    <div class="grid">
      <!-- Main form -->
      <section class="card" aria-label="Worksheet">
        <h2>What you’re producing</h2>
        <p class="muted small">
          A usable draft you can bring to seminar: <strong>8+ stakeholders</strong> for one small business and
          <strong>one key tension</strong> (trade-off) to discuss.
        </p>

        <div class="notice">
          <strong>Important:</strong> This worksheet saves your work <em>on this device</em>. Export to Word before class.
        </div>

        <div class="divider"></div>

        <h3>Step 1 — Choose your business</h3>
        <div class="fields">
          <div>
            <label for="studentName">Student name (optional)</label>
            <input id="studentName" type="text" placeholder="e.g., Alex Nguyen" />
          </div>
          <div>
            <label for="workDate">Date</label>
            <input id="workDate" type="date" />
          </div>
        </div>

        <div class="fields" style="margin-top:10px;">
          <div>
            <label for="bizName">Business name</label>
            <input id="bizName" type="text" placeholder="e.g., Neighbourhood Café (or your chosen business)" />
          </div>
          <div>
            <label for="bizServes">Who it serves</label>
            <input id="bizServes" type="text" placeholder="e.g., local residents + nearby office workers" />
          </div>
        </div>

        <div style="margin-top:10px;">
          <label for="bizSells">What it sells (1 sentence)</label>
          <input id="bizSells" type="text" placeholder="e.g., coffee + simple lunches + takeaway" />
        </div>

        <div class="divider"></div>

        <h3>Step 2 — Stakeholder map</h3>
        <p class="muted small">
          A stakeholder is anyone who can affect the business, or is affected by the business’s decisions.
          Keep your points short, but real.
        </p>

        <div style="display:flex; gap:10px; flex-wrap:wrap; margin: 8px 0 10px 0;">
          <button class="btn btn-ghost" id="addRowBtn" type="button">+ Add stakeholder row</button>
          <button class="btn btn-ghost" id="loadExampleBtn" type="button" title="Optional starter">Load café starter text</button>
        </div>

        <div class="table-wrap" role="region" aria-label="Stakeholder table" tabindex="0">
          <table id="stakeTable">
            <thead>
              <tr>
                <th style="width:22%;">Stakeholder</th>
                <th style="width:35%;">What they want / care about</th>
                <th style="width:35%;">One tension / risk / trade-off</th>
                <th style="width:8%; text-align:right;">Action</th>
              </tr>
            </thead>
            <tbody id="stakeTbody">
              <!-- Rows inserted by JS -->
            </tbody>
          </table>
        </div>

        <div class="divider"></div>

        <h3>Step 3 — Your key tension (the one you’ll discuss in class)</h3>
        <label for="keyTension" class="muted">Write it as a real trade-off (e.g., “speed vs service quality”, “growth vs control”).</label>
        <textarea id="keyTension" placeholder="My key tension to discuss in seminar is…"></textarea>

        <div class="divider"></div>

        <h3>Quick self-check</h3>
        <p class="muted small">
          Before you export: do you have <strong>8+ stakeholders</strong>, and does your tension read like a true trade-off?
        </p>

      </section>

      <!-- Right column: status + tips -->
      <aside class="right-stack">
        <section class="card status" aria-label="Progress">
          <h2 style="margin-bottom:6px;">Progress</h2>
          <div id="stakeCountBadge" class="badge warn">Stakeholders: 0 (need 8+)</div>
          <div id="tensionBadge" class="badge warn">Key tension: not yet added</div>
          <div class="tiny" id="lastSavedTxt">Last saved: —</div>
        </section>

        <section class="card" aria-label="Tips">
          <h2 style="margin-bottom:6px;">Tips (keep it simple)</h2>
          <ul class="muted small" style="margin:0; padding-left:18px;">
            <li>Be specific: name the real pressure (time/cash/people) and who feels it.</li>
            <li>Sharpen vague tensions into a trade-off: “lower prices vs quality”, “delivery sales vs margin”.</li>
            <li>If unsure, write <span class="kbd">unknown</span> and what you would check.</li>
          </ul>
        </section>

        <section class="card" aria-label="Support">
          <h2 style="margin-bottom:6px;">If your browser blocks downloads</h2>
          <p class="muted small" style="margin:0;">
            Use <strong>Print / Save as PDF</strong> in the top bar as a fallback. Then bring the PDF to class.
          </p>
        </section>
      </aside>
    </div>
  </main>

  <!-- Sticky footer with required Export to Word button -->
  <footer class="sticky-footer">
    <div class="sticky-inner">
      <div class="footer-left">
        <span class="hint">Autosave is on. Export before class.</span>
      </div>
      <div class="footer-right">
        <button class="btn btn-ghost" id="saveBtn" type="button">Save now</button>
        <button class="btn btn-danger" id="resetBtn" type="button">Reset</button>
        <button class="btn btn-primary" id="exportBtn" type="button">Export to Word (.docx)</button>
      </div>
    </div>
  </footer>

  <script>
    // ---------- Config ----------
    const STORAGE_KEY = "MMM760_W1_A1_STAKEHOLDERS_v1";

    const DEFAULT_ROWS = [
      "Customers",
      "Staff / contractors",
      "Suppliers",
      "Owner / founder",
      "Community / neighbours",
      "Regulators / compliance",
      "Finance / lenders",
      "Competitors"
    ];

    // ---------- Helpers ----------
    const $ = (id) => document.getElementById(id);

    function nowStamp(){
      const d = new Date();
      return d.toLocaleString(undefined, { year:"numeric", month:"short", day:"2-digit", hour:"2-digit", minute:"2-digit" });
    }

    function safeText(v){
      return (v ?? "").toString().trim();
    }

    function debounce(fn, delay=400){
      let t;
      return (...args) => {
        clearTimeout(t);
        t = setTimeout(() => fn(...args), delay);
      };
    }

    // ---------- Row rendering ----------
    function makeRow({ stakeholder="", wants="", tension="" } = {}){
      const tr = document.createElement("tr");

      tr.innerHTML = `
        <td class="cell-input">
          <input type="text" value="${escapeHtml(stakeholder)}" placeholder="e.g., Customers" data-field="stakeholder" />
        </td>
        <td class="cell-input">
          <textarea placeholder="What do they want / care about?" data-field="wants">${escapeHtml(wants)}</textarea>
        </td>
        <td class="cell-input">
          <textarea placeholder="One tension / risk / trade-off" data-field="tension">${escapeHtml(tension)}</textarea>
        </td>
        <td>
          <div class="row-actions">
            <button type="button" class="btn btn-danger" data-action="delete" title="Delete row">Delete</button>
          </div>
        </td>
      `;

      tr.querySelector('[data-action="delete"]').addEventListener("click", () => {
        tr.remove();
        updateBadges();
        scheduleSave();
      });

      tr.querySelectorAll("input, textarea").forEach(el => {
        el.addEventListener("input", () => {
          updateBadges();
          scheduleSave();
        });
      });

      return tr;
    }

    function renderDefaultRows(){
      const tbody = $("stakeTbody");
      tbody.innerHTML = "";
      DEFAULT_ROWS.forEach(name => tbody.appendChild(makeRow({ stakeholder:name })));
      updateBadges();
    }

    function escapeHtml(str){
      return String(str ?? "")
        .replaceAll("&","&amp;")
        .replaceAll("<","&lt;")
        .replaceAll(">","&gt;")
        .replaceAll('"',"&quot;")
        .replaceAll("'","&#039;");
    }

    // ---------- Collect / load ----------
    function collectData(){
      const rows = [];
      $("stakeTbody").querySelectorAll("tr").forEach(tr => {
        const stakeholder = tr.querySelector('[data-field="stakeholder"]').value;
        const wants = tr.querySelector('[data-field="wants"]').value;
        const tension = tr.querySelector('[data-field="tension"]').value;
        // Keep rows even if partially blank (student may be drafting)
        rows.push({ stakeholder:safeText(stakeholder), wants:safeText(wants), tension:safeText(tension) });
      });

      return {
        meta: {
          studentName: safeText($("studentName").value),
          workDate: $("workDate").value || "",
          savedAt: new Date().toISOString()
        },
        business: {
          name: safeText($("bizName").value),
          sells: safeText($("bizSells").value),
          serves: safeText($("bizServes").value)
        },
        stakeholderRows: rows,
        keyTension: safeText($("keyTension").value)
      };
    }

    function loadData(data){
      $("studentName").value = data?.meta?.studentName || "";
      $("workDate").value = data?.meta?.workDate || "";
      $("bizName").value = data?.business?.name || "";
      $("bizSells").value = data?.business?.sells || "";
      $("bizServes").value = data?.business?.serves || "";
      $("keyTension").value = data?.keyTension || "";

      const tbody = $("stakeTbody");
      tbody.innerHTML = "";
      const rows = data?.stakeholderRows?.length ? data.stakeholderRows : DEFAULT_ROWS.map(s => ({stakeholder:s, wants:"", tension:""}));
      rows.forEach(r => tbody.appendChild(makeRow(r)));

      updateBadges();
    }

    // ---------- Save / autosave ----------
    function setSavePill(text){
      $("savePill").textContent = text;
    }

    function saveNow(){
      const data = collectData();
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      const stamp = nowStamp();
      setSavePill("Saved • " + stamp);
      $("lastSavedTxt").textContent = "Last saved: " + stamp;
    }

    const scheduleSave = debounce(saveNow, 450);

    function tryRestore(){
      const raw = localStorage.getItem(STORAGE_KEY);
      if(!raw){
        renderDefaultRows();
        // Default date today
        const d = new Date();
        $("workDate").value = d.toISOString().slice(0,10);
        return;
      }
      try{
        const data = JSON.parse(raw);
        loadData(data);
        setSavePill("Restored • ready");
        if(data?.meta?.savedAt){
          $("lastSavedTxt").textContent = "Last saved: " + new Date(data.meta.savedAt).toLocaleString();
        }
      } catch(e){
        renderDefaultRows();
      }
    }

    // ---------- Badges ----------
    function updateBadges(){
      const rows = collectData().stakeholderRows || [];
      // Count rows that have a stakeholder label (not empty)
      const count = rows.filter(r => safeText(r.stakeholder).length > 0).length;

      const stakeBadge = $("stakeCountBadge");
      if(count >= 8){
        stakeBadge.className = "badge ok";
        stakeBadge.textContent = `Stakeholders: ${count} (good)`;
      } else {
        stakeBadge.className = "badge warn";
        stakeBadge.textContent = `Stakeholders: ${count} (need 8+)`;
      }

      const tension = safeText($("keyTension").value);
      const tensionBadge = $("tensionBadge");
      if(tension.length >= 8){
        tensionBadge.className = "badge ok";
        tensionBadge.textContent = "Key tension: added";
      } else {
        tensionBadge.className = "badge warn";
        tensionBadge.textContent = "Key tension: not yet added";
      }
    }

    // ---------- Optional starter text ----------
    function loadCafeStarter(){
      if(!confirm("Load a simple café starter example into the table? This won’t overwrite stakeholder names, only adds draft notes where blank.")) return;

      $("bizName").value = $("bizName").value || "Neighbourhood Café";
      $("bizSells").value = $("bizSells").value || "Coffee, simple meals, takeaway (plus optional delivery)";
      $("bizServes").value = $("bizServes").value || "Local residents + nearby office workers";

      const map = {
        "Customers": { wants:"Fast service, consistent quality, value for money", tension:"Speed vs service quality during peak times" },
        "Staff / contractors": { wants:"Fair rosters, safe workload, clear expectations", tension:"Customer demands vs staff capacity/wellbeing" },
        "Suppliers": { wants:"Reliable orders and prompt payment", tension:"Cash flow pressure vs paying suppliers on time" },
        "Owner / founder": { wants:"Profit, reputation, time/sanity", tension:"Growth opportunities vs control/time" },
        "Community / neighbours": { wants:"Low noise, good parking behaviour, local amenity", tension:"Higher foot traffic vs neighbourhood impact" },
        "Regulators / compliance": { wants:"Food safety + correct wages + record keeping", tension:"Compliance effort vs limited admin time" },
        "Finance / lenders": { wants:"Repayments on time, stable cash flow", tension:"Investing in improvements vs protecting cash buffer" },
        "Competitors": { wants:"Win customers (price/experience)", tension:"Price competition vs maintaining quality" }
      };

      $("stakeTbody").querySelectorAll("tr").forEach(tr => {
        const stakeholder = safeText(tr.querySelector('[data-field="stakeholder"]').value);
        const wantsEl = tr.querySelector('[data-field="wants"]');
        const tensionEl = tr.querySelector('[data-field="tension"]');

        if(map[stakeholder]){
          if(!safeText(wantsEl.value)) wantsEl.value = map[stakeholder].wants;
          if(!safeText(tensionEl.value)) tensionEl.value = map[stakeholder].tension;
        }
      });

      $("keyTension").value = $("keyTension").value || "Adding delivery may increase sales, but can reduce margins and increase staff pressure.";
      updateBadges();
      scheduleSave();
    }

    // ---------- Export to Word (DOCX) ----------
    async function exportToWord(){
      if(!window.docx){
        alert("DOCX export library did not load. Please use Print / Save as PDF as a fallback.");
        return;
      }

      const data = collectData();
      const { Document, Packer, Paragraph, TextRun, HeadingLevel, AlignmentType,
              Table, TableRow, TableCell, WidthType, ShadingType, BorderStyle } = window.docx;

      const tealFill = "007A78";
      const lightBorder = "D6E1E5";

      function p(text, opts={}){
        return new Paragraph({
          children: [ new TextRun({ text, ...opts }) ],
        });
      }

      function spacer(lines=1){
        return new Paragraph({ children:[new TextRun({ text:"" })], spacing:{ after: lines*120 } });
      }

      function makeHeader(text){
        return new Paragraph({
          heading: HeadingLevel.HEADING_1,
          children: [ new TextRun({ text, bold:true, color:"007A78" }) ],
          spacing: { after: 180 }
        });
      }

      function makeSubhead(text){
        return new Paragraph({
          heading: HeadingLevel.HEADING_2,
          children: [ new TextRun({ text, bold:true, color:"1F2A30" }) ],
          spacing: { before: 120, after: 120 }
        });
      }

      function cell(text, { bold=false, fill=null, color=null } = {}){
        return new TableCell({
          children: [ new Paragraph({ children:[ new TextRun({ text: text || "", bold, color: color || "1F2A30" }) ] }) ],
          shading: fill ? { type: ShadingType.CLEAR, color: "FFFFFF", fill } : undefined,
          margins: { top: 120, bottom: 120, left: 140, right: 140 },
        });
      }

      function borderAll(){
        return {
          top: { style: BorderStyle.SINGLE, size: 1, color: lightBorder },
          bottom: { style: BorderStyle.SINGLE, size: 1, color: lightBorder },
          left: { style: BorderStyle.SINGLE, size: 1, color: lightBorder },
          right: { style: BorderStyle.SINGLE, size: 1, color: lightBorder },
        };
      }

      const docTitle = "MMM760 • Week 1 • Activity 1 — Stakeholder map (draft)";
      const dateText = data.meta.workDate ? data.meta.workDate : new Date().toISOString().slice(0,10);

      // Student + business details table
      const detailsTable = new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [
          new TableRow({
            children: [
              cell("Student name", { bold:true, fill: tealFill, color:"FFFFFF" }),
              cell(data.meta.studentName || "—"),
              cell("Date", { bold:true, fill: tealFill, color:"FFFFFF" }),
              cell(dateText || "—"),
            ],
          }),
          new TableRow({
            children: [
              cell("Business name", { bold:true, fill: tealFill, color:"FFFFFF" }),
              cell(data.business.name || "—"),
              cell("Who it serves", { bold:true, fill: tealFill, color:"FFFFFF" }),
              cell(data.business.serves || "—"),
            ],
          }),
          new TableRow({
            children: [
              cell("What it sells (1 sentence)", { bold:true, fill: tealFill, color:"FFFFFF" }),
              new TableCell({
                children:[ new Paragraph({ children:[ new TextRun({ text: data.business.sells || "—" }) ] }) ],
                columnSpan: 3,
                margins: { top: 120, bottom: 120, left: 140, right: 140 },
              }),
            ],
          }),
        ].map(r => {
          r.children.forEach(c => c.borders = borderAll());
          return r;
        })
      });

      // Stakeholder map table
      const headerRow = new TableRow({
        children: [
          cell("Stakeholder", { bold:true, fill: tealFill, color:"FFFFFF" }),
          cell("What they want / care about", { bold:true, fill: tealFill, color:"FFFFFF" }),
          cell("One tension / risk / trade-off", { bold:true, fill: tealFill, color:"FFFFFF" }),
        ].map(c => { c.borders = borderAll(); return c; })
      });

      const bodyRows = (data.stakeholderRows || []).map(r => {
        const row = new TableRow({
          children: [
            cell(r.stakeholder || "—"),
            cell(r.wants || "—"),
            cell(r.tension || "—"),
          ].map(c => { c.borders = borderAll(); return c; })
        });
        return row;
      });

      const stakeTable = new Table({
        width: { size: 100, type: WidthType.PERCENTAGE },
        rows: [headerRow, ...bodyRows],
      });

      const doc = new Document({
        sections: [{
          properties: {},
          children: [
            makeHeader(docTitle),

            p("This is a draft worksheet for seminar preparation. Keep it short, specific, and usable.", { italics:true, color:"5B6B75" }),
            spacer(1),

            makeSubhead("Business context"),
            detailsTable,
            spacer(1),

            makeSubhead("Stakeholder map"),
            stakeTable,
            spacer(1),

            makeSubhead("My key tension to discuss in seminar"),
            new Paragraph({ children:[ new TextRun({ text: data.keyTension || "—" }) ] }),

            spacer(1),
            new Paragraph({
              alignment: AlignmentType.CENTER,
              children: [ new TextRun({ text:"Generated from MMM760 Week 1 worksheet", color:"5B6B75", size:18 }) ]
            })
          ]
        }]
      });

      const blob = await Packer.toBlob(doc);
      const filenameSafeBiz = (data.business.name || "Business").replace(/[^\w\-]+/g,"_").slice(0,40);
      const filename = `MMM760_W1_A1_StakeholderMap_${filenameSafeBiz}.docx`;

      // file-saver preferred
      if(window.saveAs){
        window.saveAs(blob, filename);
      } else {
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url; a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }
    }

    // ---------- Wire up ----------
    function bindAutosave(){
      ["studentName","workDate","bizName","bizSells","bizServes","keyTension"].forEach(id => {
        $(id).addEventListener("input", () => { updateBadges(); scheduleSave(); });
      });
    }

    function addRow(){
      $("stakeTbody").appendChild(makeRow({}));
      updateBadges();
      scheduleSave();
    }

    function resetAll(){
      if(!confirm("Reset this worksheet? This clears the saved draft on this device.")) return;
      localStorage.removeItem(STORAGE_KEY);
      $("studentName").value = "";
      $("bizName").value = "";
      $("bizSells").value = "";
      $("bizServes").value = "";
      $("keyTension").value = "";
      const d = new Date();
      $("workDate").value = d.toISOString().slice(0,10);
      renderDefaultRows();
      setSavePill("Reset • not saved");
      $("lastSavedTxt").textContent = "Last saved: —";
    }

    window.addEventListener("DOMContentLoaded", () => {
      tryRestore();
      bindAutosave();

      $("addRowBtn").addEventListener("click", addRow);
      $("saveBtn").addEventListener("click", saveNow);
      $("resetBtn").addEventListener("click", resetAll);
      $("exportBtn").addEventListener("click", exportToWord);
      $("loadExampleBtn").addEventListener("click", loadCafeStarter);

      // First save pill state (after restore)
      setTimeout(() => updateBadges(), 50);
    });
  </script>
</body>
</html>
